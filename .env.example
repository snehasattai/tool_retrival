GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

ORCHESTRATOR_MODEL=gemini-2.5-flash
SUB_AGENT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001

TOOL_RETRIEVAL_TOP_K=5
DECOY_TOOL_COUNT=460

CHROMA_DB_DIR=.chroma

# Optional: observability. Send ADK's native OpenTelemetry spans straight to
# LangSmith -- adk web / adk api_server auto-detect
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT and wire the exporter themselves, no
# application code needed. Leave blank to skip LangSmith tracing entirely.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=paypal-adk-assistant
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://api.smith.langchain.com/otel/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=x-api-key=<your-langsmith-api-key>,Langsmith-Project=paypal-adk-assistant
